# Database
DATABASE_URL=postgresql://user:password@localhost:5432/brivia_eats

# AMap Web Service key - server-side only.
# Create in AMap console as Web服务.
AMAP_WEB_SERVICE_KEY=

# AMap JS API key - client-side, domain-whitelisted in AMap console.
# Create in AMap console as Web端(JS API).
NEXT_PUBLIC_AMAP_JS_KEY=

# AMap JS API security code.
# This is the 安全密钥 value shown next to the Web端(JS API) key in the AMap console.
NEXT_PUBLIC_AMAP_SECURITY_CODE=

# Temporary MVP portal login token.
# Generate with: openssl rand -hex 32
PORTAL_ADMIN_TOKEN=

# Used to translate AMap POI cards into English.
OPENAI_API_KEY=
OPENAI_TRANSLATION_MODEL=gpt-4.1-mini
